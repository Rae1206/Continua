# ============================================
# Environment Variables — Keep Going (continua)
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================

# --- Supabase ---
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Firebase Cloud Messaging ---
# For Supabase Edge Function (send-notification)
# Get from: Google Cloud Console > APIs & Services > Credentials
FCM_SERVER_KEY=your-fcm-server-key-here
GOOGLE_PROJECT_ID=your-google-project-id

# --- Firebase (Flutter app) ---
# For android/app/google-services.json — download from Firebase Console
# For ios/Runner/GoogleService-Info.plist — download from Firebase Console
# These files are NOT committed to git. Each developer must download their own.

# --- OpenAI (optional — for Supabase AI features) ---
# OPENAI_API_KEY=your-openai-key-here

# --- S3 Storage (optional — if using Supabase S3 backend) ---
# S3_HOST=your-s3-host
# S3_REGION=your-s3-region
# S3_ACCESS_KEY=your-s3-access-key
# S3_SECRET_KEY=your-s3-secret-key

# --- Twilio (optional — for SMS auth) ---
# SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=your-twilio-account-sid
# SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your-twilio-auth-token
# SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=your-twilio-message-sid
